{
  "roles": {
    "developer": {
      "permissions": [
        "filesystem:read",
        "filesystem:write",
        "sandbox:orchestrate",
        "slack:notify",
        "agent:trigger"
      ]
    },
    "architect": {
      "permissions": [
        "filesystem:read",
        "architecture:review",
        "schema:design",
        "agent:trigger"
      ]
    },
    "security": {
      "permissions": [
        "filesystem:read",
        "repo:scan",
        "security:audit"
      ]
    },
    "manager": {
      "permissions": [
        "backlog:read",
        "backlog:write",
        "report:generate",
        "agent:trigger"
      ]
    },
    "restricted": {
      "permissions": [
        "filesystem:read"
      ]
    }
  },
  "agent_roles": {
    "developer_dex": "developer",
    "DeveloperDexAgent": "developer",
    "architect_artoo": "architect",
    "ArchitectArtooAgent": "architect",
    "security_architect": "security",
    "SecurityArchitectAgent": "security",
    "product_poe": "manager",
    "ProductPoeAgent": "manager",
    "report_revan": "manager",
    "ReportRevanAgent": "manager",
    "thoughtful_thrawn": "restricted",
    "ThoughtfulThrawnAgent": "restricted",
    "vibe_vader": "restricted",
    "VibeVaderAgent": "restricted",
    "quality_quigon": "developer",
    "QualityQuigonAgent": "developer"
  },
  "path_grants": {
    "vibe_vader": [
      ".exegol/user_action_required.md",
      ".exegol/user_action_required.json"
    ],
    "thoughtful_thrawn": [
      ".exegol/intent.md",
      ".exegol/user_action_required.json",
      "README.md"
    ]
  },
  "global_restrictions": {
    "filesystem:delete": "requires_hitl",
    "system:command": "requires_hitl",
    "credential:access": "requires_hitl"
  }
}
